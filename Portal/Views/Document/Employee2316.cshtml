@model List<APWModel.ViewModel.ACAP.Employee_model.Employee2316File>


@{
    ViewBag.Title = "2316 Report";
}

@section Scripts{
    <script src="~/Scripts/Document/Document.js"></script>
}

<section class="main">
    <div class="main-title py-3 border-bottom bg-white">
        <div class="container-fluid">
            <div class="row justify-content-between align-items-center">
                <div class="col-lg-auto text-center text-lg-start mb-lg-0">
                    <h1 class="h4 mt-2 mb-lg-0 text-primary fw-bold">BIR Form 2316</h1>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0 small">
                            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Document")">Document</a></li>
                            <li class="breadcrumb-item active" aria-current="page">2316 Report</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>

    <div class="main-content py-4 bg-light min-vh-100">
        <div class="container-fluid">
            <div class="row g-3">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <div class="col-6 col-md-4 col-lg-2">
                            <a href="@item.FileUrl" target="_blank" class="folder-card text-decoration-none">
                                <div class="card h-100 border-0 shadow-sm text-center p-3 transition-up">
                                    <div class="folder-icon mb-2">
                                        <i class="fa-solid fa-folder shadow-icon"></i>
                                        <span class="file-badge">PDF</span>
                                    </div>
                                    <h6 class="text-dark fw-bold mb-1">Year @item.FolderYear</h6>
                                    <p class="text-muted small mb-0">BIR Form 2316</p>
                                </div>
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="alert alert-info border-start border-4 border-info">
                            <i class="fa-solid fa-circle-info me-2"></i> No 2316 reports have been uploaded to your profile yet.
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <footer class="footer py-3 bg-light border-top fixed-bottom">
        <div class="container-fluid text-center">
            <span class="text-muted small">
                Powered By: <a href="https://asiapeopleworks.com.ph/" target="_blank" class="text-decoration-none">Asia Peopleworks</a>
            </span>
        </div>
    </footer>
</section>

<style>
    .folder-card .card {
        background: #ffffff;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .folder-icon {
        position: relative;
        font-size: 4rem;
        color: #ffca28;
    }

    .shadow-icon {
        filter: drop-shadow(2px 4px 6px rgba(0,0,0,0.1));
    }

    .file-badge {
        position: absolute;
        bottom: 15px;
        right: 25%;
        background: #dc3545;
        color: white;
        font-size: 0.6rem;
        padding: 2px 5px;
        border-radius: 4px;
        font-weight: bold;
    }

    .transition-up:hover {
        transform: translateY(-5px);
        background-color: #fcfcfc !important;
    }

    .folder-card:hover .folder-icon {
        color: #ffb300;
        transform: scale(1.05);
        transition: 0.2s;
    }

    .folder-card:hover h6 {
        color: #0d6efd;
    }
</style>