@using (Html.BeginForm("_AddCorrection", "Attendance", FormMethod.Post, new { enctype = "multipart/form-data", name = "edit-attendance-correction-Form", id = "edit-attendance-correction-Form" }))
{
    @Html.HiddenFor(m => m.Id)
    @Html.HiddenFor(m => m.UserId)
    @Html.HiddenFor(m => m.EmpId)
    @Html.HiddenFor(m => m.Remarks)

    @Html.HiddenFor(m => m.HasAttachement)
    @Html.HiddenFor(m => m.FileExtension)

    @Html.Partial("~/Views/Shared/_atdcorrection_instruction.cshtml")

    <div class="row" id="div-validation" style="display: none;">
        <div class="col mb-3">
            <label for="html" id="error-message-label" class="form-label text-danger"></label><br>
        </div>
    </div>

    <div style="display:none;">
        @Html.TextBoxFor(m => m.DateLog, new { @type = "date", @Value = Model.DateLog.ToString("yyyy-MM-dd"), @id = "DateLog" })
    </div>

    <div class="row mb-3">
        <div class="col-6">
            <label for="" class="form-label">Work Location</label>
            @Html.DropDownListFor(m => m.WorkLocation,
                new List<SelectListItem> {
                    new SelectListItem { Text = "Office", Value = "1" },
                    new SelectListItem { Text = "Home", Value = "2" },
                    new SelectListItem { Text = "Onsite Work", Value = "3" }
                },
                "Please Select",
                new { @class = "form-select" })
        </div>
        <div class="col-6"></div>
    </div>

    <div class="row mb-3">
        <div class="col-12">
            <label for="" class="form-label">Shift</label>
            @Html.DropDownListFor(m => m.ShiftId, (IEnumerable<SelectListItem>)ViewBag._ClientShift, "Please Select", new { @class = "form-select", @placeholder = "Shift" })
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-12">
            <label for="" class="form-label">Time In</label>
        </div>
        <div class="col-6">
            @Html.TextBoxFor(m => m.TimeInDate, new { @class = "form-control", @placeholder = "mm/dd/yyyy", @type = "date", @Value = Model.TimeInDate.ToString("yyyy-MM-dd"), @id = "TimeInDate" })
        </div>
        <div class="col-6">
            @Html.TextBoxFor(m => m.TimeInTime, new { @class = "form-control", @placeholder = "Time Out", @type = "time", @Value = Model.TimeInTime.ToString("HH:mm"), @id = "TimeInTime" })
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-12">
            <label for="" class="form-label">Time Out</label>
        </div>
        <div class="col-6">
            @Html.TextBoxFor(m => m.TimeOutDate, new { @class = "form-control", @placeholder = "mm/dd/yyyy", @type = "date", @Value = Model.TimeOutDate.ToString("yyyy-MM-dd"), @id = "TimeOutDate" })
        </div>
        <div class="col-6">
            @Html.TextBoxFor(m => m.TimeOutTime, new { @class = "form-control", @placeholder = "Time Out", @type = "time", @Value = Model.TimeOutTime.ToString("HH:mm"), @id = "TimeOutTime" })
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-12">
            <label class="form-label-custom">Reason for Attendance correction</label>
            @Html.TextAreaFor(m => m.Reason, 3, 40, new { @class = "form-control", @placeholder = "Briefly explain the reason for applying an Attendance correction..." })
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-12">
            <label class="form-label-custom">Update Attachment (Optional)</label>
            <input class="form-control" type="file" name="Edit_Correction_Attachment" id="Edit_Correction_Attachment">
        </div>
    </div>
}

<script type="text/javascript">
    (function () {
        function initDateSync() {
            var timeInDateInput = document.getElementById("TimeInDate");
            var timeOutDateInput = document.getElementById("TimeOutDate");
            var dateLogInput = document.getElementById("DateLog");

            if (timeInDateInput) {
                var syncDates = function () {
                    var selectedValue = timeInDateInput.value;

                    if (timeOutDateInput) {
                        timeOutDateInput.value = selectedValue;
                    }
                    if (dateLogInput) {
                        dateLogInput.value = selectedValue;
                    }
                };

                timeInDateInput.addEventListener("input", syncDates);
                timeInDateInput.addEventListener("change", syncDates);
            }
        }

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", initDateSync);
        } else {
            initDateSync();
        }
    })();
</script>