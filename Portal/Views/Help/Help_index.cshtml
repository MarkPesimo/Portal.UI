                            @Html.Partial("./partial/Help_item_bytype", Model.LeaveHelp)
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="accordion-item category-grid-card shadow-sm border-0">
                    <h5 class="accordion-header" id="header-7">
                        <a class="accordion-button collapsed widget fs-6 fw-bold d-flex align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#faqs-7" aria-expanded="false" aria-controls="faqs-7">
                            <div class="category-icon-wrapper me-3"><i class="fa-solid fa-user-clock text-primary"></i></div>
                            <span>ATTENDANCE</span>
                        </a>
                    </h5>
                    <div id="faqs-7" class="accordion-collapse collapse widget p-0" aria-labelledby="header-7" data-bs-parent="#faqs">
                        <div class="accordion-body p-0">
                            @Html.Partial("./partial/Help_item_bytype", Model.AttendanceHelp)
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="accordion-item category-grid-card shadow-sm border-0">
                    <h5 class="accordion-header" id="header-8">
                        <a class="accordion-button collapsed widget fs-6 fw-bold d-flex align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#faqs-8" aria-expanded="false" aria-controls="faqs-8">
                            <div class="category-icon-wrapper me-3"><i class="fa-solid fa-clock-rotate-left text-primary"></i></div>
                            <span>CORRECTION</span>
                        </a>
                    </h5>
                    <div id="faqs-8" class="accordion-collapse collapse widget p-0" aria-labelledby="header-8" data-bs-parent="#faqs">
                        <div class="accordion-body p-0">
                            @Html.Partial("./partial/Help_item_bytype", Model.AttendanceCorrectionHelp)
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="accordion-item category-grid-card shadow-sm border-0">
                    <h5 class="accordion-header" id="header-9">
                        <a class="accordion-button collapsed widget fs-6 fw-bold d-flex align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#faqs-9" aria-expanded="false" aria-controls="faqs-9">
                            <div class="category-icon-wrapper me-3"><i class="fa-solid fa-calendar-days text-primary"></i></div>
                            <span>DTR</span>
                        </a>
                    </h5>
                    <div id="faqs-9" class="accordion-collapse collapse widget p-0" aria-labelledby="header-9" data-bs-parent="#faqs">
                        <div class="accordion-body p-0">
                            @Html.Partial("./partial/Help_item_bytype", Model.DTRHelp)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="footer py-4 bg-white border-top mt-auto">
        <div class="container text-center">
            <span class="text-muted small">Powered By: Asia Peopleworks</span>
        </div>
    </footer>
</section>

@Html.Partial("~/Views/Help/Modal/preview_modal.cshtml")