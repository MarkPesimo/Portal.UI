@using APWModel.ViewModel.Global

<nav class="navbar fixed-top navbar-expand-lg bg-dark " data-bs-theme="dark" id="nav-main">
    <div class="container-fluid">
        <a class="navbar-brand" href="https://www.asiapeopleworks.com.ph">
            <img src="~/Content/images/logos/APW-Logo-05.png" alt=""> <strong>Portal</strong>
        </a>

        <div class="d-flex align-items-center d-lg-none">
            <div class="nav-item dropdown me-2">
                <a class="nav-link position-relative notification-pulse" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fa-regular fa-bell fa-lg text-white"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger badge-pulse">
                        1
                    </span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow" style="min-width: 320px; position: absolute !important;">
                    @NotificationContent()
                </ul>
            </div>

            <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>

        <div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasNavbar" aria-labelledby="offcanvasNavbarLabel">
            <div class="offcanvas-header">
                <h5 class="offcanvas-title" id="offcanvasNavbarLabel">Menu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>

            <div class="offcanvas-body align-items-center" id="nav-header">
                <ul class="navbar-nav navbar-nav-left justify-content-start flex-grow-1 pe-lg-3 ps-lg-2 mb-3 mb-lg-0 pb-3 pb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link active" id="nav-Home" aria-current="page" href="@Url.Action("Index", "Home")">Home</a>
                    </li>
                    <li class="nav-item" @((User as ContextLoginUser_model).PayrollMenuVisibility)>
                        <a class="nav-link " id="nav-Payroll" href="@Url.Action("Index", "Payroll")">Payroll</a>
                    </li>
                    <li class="nav-item" @((User as ContextLoginUser_model).OvertimeMenuVisibility)>
                        <a class="nav-link " id="nav-Overtime" href="@Url.Action("Index", "Overtime")">Overtime</a>
                    </li>
                    <li class="nav-item" @((User as ContextLoginUser_model).LeaveMenuVisibility)>
                        <a class="nav-link " id="nav-Leave" href="@Url.Action("Index", "Leave")">Leave</a>
                    </li>
                    <li class="nav-item" @((User as ContextLoginUser_model).AttendanceMenuVisibility)>
                        <a class="nav-link " id="nav-Attendance" href="@Url.Action("Index", "Attendance")">Attendance</a>
                    </li>
                    <li class="nav-item" @((User as ContextLoginUser_model).DocumentMenuVisibility)>
                        <a class="nav-link " id="nav-Document" href="@Url.Action("Index", "Document")">Documents</a>
                    </li>
                    <li class="nav-item" @((User as ContextLoginUser_model).HelpdeskMenuVisibility)>
                        <a class="nav-link " id="nav-Helpdesk" href="@Url.Action("Index", "Helpdesk")">Helpdesk</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link " id="nav-Help" href="@Url.Action("Index", "Help")">Quick Guide</a>
                    </li>
                </ul>

                <ul class="navbar-nav justify-content-end flex-grow-1">
                    <li class="nav-item mt-1" @((User as ContextLoginUser_model).AttendanceMenuVisibility)>
                        <div class="d-flex align-items-center clock-actions-wrapper">
                            <button class="btn btn-sm me-2 btn-outline-light my-2 my-sm-0 shadow-sm" id="my-shift" current-date="" disabled>
                                <i class="fa-solid fa-calendar-day me-1"></i> Shift: Loading...
                            </button>

                            <button class="btn btn-sm me-2 btn-outline-light my-2 my-sm-0 clock-btn clock-in" id="clock-in-button" data-clockin-value="" type="submit">
                                <i class="fa-solid fa-door-open me-1"></i> Clock In
                            </button>

                            <button class="btn btn-sm me-2 btn-outline-light my-2 my-sm-0 clock-btn clock-out" id="clock-out-button" data-clockout-value="" type="submit">
                                <i class="fa-solid fa-right-from-bracket me-1"></i> Clock Out
                            </button>
                        </div>
                    </li>

                    <li class="nav-item dropdown ms-lg-2 d-none d-lg-block">
                        <a class="nav-link position-relative notification-pulse" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fa-regular fa-bell fa-lg"></i>
                            <span class="position-absolute top-2 start-75 translate-middle badge rounded-pill bg-danger badge-pulse" id="notification-count">
                                1
                            </span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="notificationDropdown" style="min-width: 320px;">
                            @NotificationContent()
                        </ul>
                    </li>

                    <li class="nav-item dropdown ms-lg-2">
                        <a class="nav-link nav-link-profile dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="\CandidateImages\@((User as ContextLoginUser_model).CandidateId).JPEG" class="me-1 rounded" alt="">
                            @((User as ContextLoginUser_model).Username)
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="@Url.Action("Index", "Profile")">Profile</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Index", "Settings")">Settings</a></li>
                            <li><a class="dropdown-item" href="#" id="logout-menu">Sign Out</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</nav>

@helper NotificationContent()
{
    <li class="dropdown-header border-bottom d-flex justify-content-between align-items-center">
        <span class="fw-bold text-white">Portal Updates</span>
        <span class="badge bg-primary text-uppercase" style="font-size: 0.6rem;">New</span>
    </li>
    <li>
        <a class="dropdown-item py-3" href="@Url.Action("Index", "Help")">
            <div class="d-flex align-items-center">
                <div class="flex-shrink-0 me-3">
                    <div class="bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                        <i class="fa-solid fa-file-pdf"></i>
                    </div>
                </div>
                <div class="flex-grow-1">
                    <div class="small text-muted">Resources</div>
                    <div class="fw-semibold" style="font-size: 0.85rem;">Portal Infographics Available</div>
                    <div class="small text-wrap text-muted" style="font-size: 0.75rem;">Check the new "How-to" filing guide.</div>
                </div>
            </div>
        </a>
    </li>
    <li><hr class="dropdown-divider m-0"></li>
    <li>
        <a class="dropdown-item text-center py-2 small text-primary fw-bold" href="@Url.Action("Index", "Help")">
            View All Guides & Notifications
        </a>
    </li>
}

<style>

    .notification-pulse i {
        animation: ring 4s .7s ease-in-out infinite;
        transform-origin: 50% 4px;
        display: inline-block;
    }

    .badge-pulse {
        animation: pulse-red 2s infinite;
    }

    @@keyframes ring {
        0%, 40%, 100% {
            transform: rotate(0);
        }

        1%, 3% {
            transform: rotate(30deg);
        }

        2%, 4% {
            transform: rotate(-28deg);
        }
    }

    @@keyframes pulse-red {
        0% {
            transform: scale(0.95) translate(-50%, -50%);
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7);
        }

        70% {
            transform: scale(1.1) translate(-50%, -50%);
            box-shadow: 0 0 0 10px rgba(220, 53, 69, 0);
        }

        100% {
            transform: scale(0.95) translate(-50%, -50%);
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
        }
    }
</style>